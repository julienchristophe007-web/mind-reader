<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>🔮 Mind Reader</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background: #f5f4f0;
      min-height: 100vh;
      display: flex;
      align-items: flex-start;
      justify-content: center;
      padding: 2rem 1rem;
    }

    #app { width: 100%; max-width: 620px; }

    .header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 1.5rem;
    }

    .title { font-size: 22px; font-weight: 600; color: #1a1a1a; }

    .counter {
      font-size: 13px;
      color: #666;
      background: #fff;
      padding: 4px 12px;
      border-radius: 20px;
      border: 1px solid #e0e0e0;
    }

    .progress {
      height: 5px;
      background: #e8e8e8;
      border-radius: 4px;
      margin-bottom: 1.5rem;
      overflow: hidden;
    }

    .progress-fill {
      height: 100%;
      background: linear-gradient(90deg, #7F77DD, #534AB7);
      border-radius: 4px;
      transition: width 0.4s ease;
    }

    .card {
      background: #fff;
      border: 1px solid #e8e8e8;
      border-radius: 16px;
      padding: 1.5rem;
      margin-bottom: 1rem;
    }

    .card-label {
      font-size: 11px;
      font-weight: 600;
      color: #999;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      margin-bottom: 10px;
    }

    .question-text { font-size: 18px; color: #1a1a1a; line-height: 1.5; }
    .thinking { font-size: 14px; color: #999; font-style: italic; }

    .btns { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 1rem; }

    button {
      padding: 10px 22px;
      border-radius: 10px;
      border: 1px solid #d0d0d0;
      background: transparent;
      color: #1a1a1a;
      font-size: 15px;
      cursor: pointer;
      transition: background 0.15s, transform 0.1s;
      font-family: inherit;
    }
    button:hover { background: #f5f5f5; }
    button:active { transform: scale(0.97); }

    .btn-yes { border-color: #1D9E75; color: #0a6647; }
    .btn-yes:hover { background: #e8f8f2; }
    .btn-no { border-color: #D85A30; color: #8f3a1b; }
    .btn-no:hover { background: #fdf0ea; }
    .btn-maybe { border-color: #c48a1a; color: #7a5510; }
    .btn-maybe:hover { background: #fef6e4; }
    .btn-primary { background: #1a1a1a; color: #fff; border-color: transparent; }
    .btn-primary:hover { background: #333; }
    .btn-ghost { font-size: 13px; color: #666; padding: 8px 16px; }

    .history {
      max-height: 180px;
      overflow-y: auto;
      display: flex;
      flex-direction: column;
      gap: 6px;
      margin-bottom: 1rem;
    }

    .hist-item {
      display: flex;
      justify-content: space-between;
      font-size: 13px;
      padding: 7px 12px;
      background: #f9f9f9;
      border-radius: 8px;
      border: 1px solid #efefef;
    }
    .hist-q { color: #666; flex: 1; margin-right: 12px; }
    .hist-a { font-weight: 600; color: #1a1a1a; white-space: nowrap; }

    .result-center { text-align: center; padding: 2rem 1rem; }
    .result-icon { font-size: 52px; margin-bottom: 14px; }
    .result-title { font-size: 24px; font-weight: 600; color: #1a1a1a; margin-bottom: 8px; }
    .result-sub { font-size: 15px; color: #666; margin-bottom: 1.5rem; line-height: 1.6; }

    .guess-box {
      background: #f5f4f0;
      border-radius: 14px;
      padding: 1.25rem 1.5rem;
      margin-bottom: 1.5rem;
      text-align: left;
      border: 1px solid #e8e7e3;
    }
    .guess-label { font-size: 12px; color: #999; margin-bottom: 4px; }
    .guess-name { font-size: 26px; font-weight: 600; color: #1a1a1a; }
    .guess-conf { font-size: 12px; margin-top: 6px; }

    input[type="text"], input[type="password"], select {
      width: 100%;
      padding: 11px 14px;
      border-radius: 10px;
      border: 1px solid #d0d0d0;
      background: #fff;
      color: #1a1a1a;
      font-size: 15px;
      margin-bottom: 10px;
      outline: none;
      font-family: inherit;
    }
    input:focus, select:focus { border-color: #7F77DD; box-shadow: 0 0 0 3px rgba(127,119,221,0.15); }

    .setup-box {
      background: #fff;
      border-radius: 16px;
      padding: 1.75rem;
      border: 1px solid #e8e8e8;
    }

    .setup-title { font-size: 17px; font-weight: 600; color: #1a1a1a; margin-bottom: 6px; }
    .setup-sub { font-size: 13px; color: #666; margin-bottom: 18px; line-height: 1.6; }
    .setup-sub a { color: #534AB7; text-decoration: none; }
    .setup-sub a:hover { text-decoration: underline; }

    .field-label { font-size: 12px; font-weight: 600; color: #555; margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.04em; }

    .key-note { font-size: 12px; color: #aaa; margin-top: 12px; line-height: 1.6; }

    .err {
      font-size: 13px;
      color: #8f3a1b;
      background: #fdf0ea;
      padding: 10px 14px;
      border-radius: 8px;
      margin-bottom: 12px;
    }

    .key-badge {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      font-size: 12px;
      color: #534AB7;
      background: #eeedfe;
      padding: 4px 10px;
      border-radius: 20px;
      border: none;
      cursor: pointer;
      font-family: inherit;
    }
    .key-badge:hover { background: #dddcfc; }

    .divider { height: 1px; background: #f0f0f0; margin: 14px 0; }

    .model-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
      margin-bottom: 10px;
    }

    .model-card {
      border: 1px solid #e0e0e0;
      border-radius: 10px;
      padding: 10px 12px;
      cursor: pointer;
      transition: border-color 0.15s, background 0.15s;
      background: #fff;
    }
    .model-card:hover { border-color: #7F77DD; background: #faf9ff; }
    .model-card.selected { border-color: #534AB7; background: #eeedfe; }
    .model-card-name { font-size: 13px; font-weight: 600; color: #1a1a1a; }
    .model-card-desc { font-size: 11px; color: #999; margin-top: 2px; }
    .model-card-price { font-size: 11px; color: #0a6647; margin-top: 3px; font-weight: 500; }
  </style>
</head>
<body>
<div id="app">
  <div class="header">
    <div class="title">🔮 Mind Reader</div>
    <div style="display:flex;align-items:center;gap:8px;">
      <button class="key-badge" id="key-badge" onclick="resetKey()" style="display:none">⚙️ Settings</button>
      <div class="counter" id="counter" style="display:none">Question 0 / 20</div>
    </div>
  </div>
  <div class="progress" id="prog-wrap" style="display:none">
    <div class="progress-fill" id="prog" style="width:0%"></div>
  </div>
  <div id="main"></div>
</div>

<script>
const MAX_Q = 20;
let history = [], questionCount = 0, currentQuestion = '', learnedFacts = [], apiKey = '', selectedModel = '';

const MODELS = [
  { id: 'google/gemini-flash-1.5',          name: 'Gemini Flash 1.5',  desc: 'Fast & smart',     price: 'Very cheap' },
  { id: 'meta-llama/llama-3.1-8b-instruct', name: 'Llama 3.1 8B',     desc: 'Open source',      price: 'Free tier' },
  { id: 'openai/gpt-4o-mini',               name: 'GPT-4o Mini',      desc: 'OpenAI, reliable', price: 'Cheap' },
  { id: 'anthropic/claude-haiku-4-5',       name: 'Claude Haiku',     desc: 'Fast & sharp',     price: 'Cheap' },
  { id: 'openai/gpt-4o',                    name: 'GPT-4o',           desc: 'Most capable',     price: 'Moderate' },
  { id: 'anthropic/claude-sonnet-4-5',      name: 'Claude Sonnet',    desc: 'Very smart',       price: 'Moderate' },
];

const DEFAULT_MODEL = 'google/gemini-flash-1.5';

function loadState() {
  try { learnedFacts = JSON.parse(localStorage.getItem('ak_learned') || '[]'); } catch(e) { learnedFacts = []; }
  apiKey = localStorage.getItem('ak_or_key') || '';
  selectedModel = localStorage.getItem('ak_model') || DEFAULT_MODEL;
}

function saveLearned(fact) {
  learnedFacts.push(fact);
  try { localStorage.setItem('ak_learned', JSON.stringify(learnedFacts.slice(-300))); } catch(e) {}
}

function setCounter(n) {
  document.getElementById('counter').textContent = `Question ${n} / ${MAX_Q}`;
  document.getElementById('prog').style.width = Math.min((n / MAX_Q) * 100, 100) + '%';
}

function render(html) { document.getElementById('main').innerHTML = html; }

function showUI(visible) {
  document.getElementById('key-badge').style.display = visible ? 'inline-flex' : 'none';
  document.getElementById('counter').style.display = visible ? 'block' : 'none';
  document.getElementById('prog-wrap').style.display = visible ? 'block' : 'none';
}

function resetKey() { showUI(false); showSetup(); }

function showSetup(errMsg) {
  showUI(false);
  const modelCards = MODELS.map(m => `
    <div class="model-card ${selectedModel === m.id ? 'selected' : ''}" onclick="selectModel('${m.id}', this)">
      <div class="model-card-name">${m.name}</div>
      <div class="model-card-desc">${m.desc}</div>
      <div class="model-card-price">${m.price}</div>
    </div>
  `).join('');

  render(`
    <div class="setup-box">
      <div class="setup-title">Connect to OpenRouter</div>
      <div class="setup-sub">
        Get a free API key at <a href="https://openrouter.ai/keys" target="_blank">openrouter.ai/keys</a> —
        many models have free tiers or cost fractions of a cent per game.
      </div>
      ${errMsg ? `<div class="err">${errMsg}</div>` : ''}
      <div class="field-label">Your OpenRouter API key</div>
      <input type="password" id="key-input" placeholder="sk-or-v1-..." value="${apiKey}" />
      <div class="field-label">Choose a model</div>
      <div class="model-grid">${modelCards}</div>
      <div style="font-size:12px;color:#aaa;margin-bottom:12px;" id="model-note">
        Selected: <strong>${MODELS.find(m => m.id === selectedModel)?.name || selectedModel}</strong>
      </div>
      <div class="divider"></div>
      <button class="btn-primary" onclick="saveSetup()" style="width:100%;padding:12px;font-size:15px;">Save & play →</button>
      <div class="key-note">
        Your key is saved in this browser's localStorage only and sent directly to openrouter.ai. Nothing is shared with anyone else.
      </div>
    </div>
  `);

  setTimeout(() => {
    const inp = document.getElementById('key-input');
    if (inp) inp.addEventListener('keydown', e => { if (e.key === 'Enter') saveSetup(); });
  }, 50);
}

function selectModel(id, el) {
  selectedModel = id;
  document.querySelectorAll('.model-card').forEach(c => c.classList.remove('selected'));
  el.classList.add('selected');
  const note = document.getElementById('model-note');
  if (note) note.innerHTML = `Selected: <strong>${MODELS.find(m => m.id === id)?.name || id}</strong>`;
}

function saveSetup() {
  const val = (document.getElementById('key-input').value || '').trim();
  if (!val.startsWith('sk-or-')) {
    showSetup('That doesn\'t look right. Your OpenRouter key should start with sk-or-...');
    return;
  }
  apiKey = val;
  try {
    localStorage.setItem('ak_or_key', val);
    localStorage.setItem('ak_model', selectedModel);
  } catch(e) {}
  showUI(true);
  showStart();
}

async function callAI(prompt, maxTokens) {
  const res = await fetch('https://openrouter.ai/api/v1/chat/completions', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'Authorization': `Bearer ${apiKey}`,
      'HTTP-Referer': 'https://mind-reader-game.local',
      'X-Title': 'Mind Reader Game'
    },
    body: JSON.stringify({
      model: selectedModel,
      max_tokens: maxTokens || 200,
      messages: [{ role: 'user', content: prompt }]
    })
  });

  if (!res.ok) {
    const err = await res.json().catch(() => ({}));
    const msg = err?.error?.message || res.statusText;
    if (res.status === 401) throw new Error('Invalid API key. Please check and re-enter it.');
    throw new Error(msg);
  }

  const data = await res.json();
  return data.choices?.[0]?.message?.content?.trim() || '';
}

function showStart() {
  history = []; questionCount = 0; setCounter(0);
  const modelName = MODELS.find(m => m.id === selectedModel)?.name || selectedModel;
  render(`
    <div class="card" style="text-align:center;padding:2.5rem 1.5rem;">
      <div style="font-size:52px;margin-bottom:14px;">🔮</div>
      <div style="font-size:20px;font-weight:600;color:#1a1a1a;margin-bottom:10px;">Think of anything</div>
      <div style="font-size:14px;color:#666;margin-bottom:6px;line-height:1.7;">
        A person, animal, object, place, concept, movie, food —<br>anything at all. I'll try to guess it in 20 questions.
      </div>
      <div style="font-size:12px;color:#aaa;margin-bottom:1.75rem;">Using <strong>${modelName}</strong></div>
      <button class="btn-primary" onclick="askQuestion()" style="font-size:16px;padding:12px 32px;">I'm ready →</button>
    </div>
  `);
}

async function askQuestion() {
  if (questionCount >= MAX_Q) { makeGuess(); return; }
  render(`<div class="card"><div class="thinking">Thinking of a clever question...</div></div>`);

  const learnedHint = learnedFacts.length > 0
    ? `\nFrom past games, people have thought of: ${[...new Set(learnedFacts.map(f => f.answer || f).filter(Boolean))].slice(-40).join(', ')}.`
    : '';

  const histText = history.map(h => `Q: ${h.q}\nA: ${h.a}`).join('\n');
  const prompt = `You are playing a 20-questions guessing game. The user is thinking of something — it can be a person, animal, object, place, concept, movie, food, or anything else.

Questions and answers so far:
${histText || 'None yet.'}
${learnedHint}

This is question ${questionCount + 1} of ${MAX_Q}.

Ask ONE smart yes/no question to narrow down the answer.
- Early questions: broad (Is it alive? Is it a physical object? Is it a person?)
- Later questions: specific based on prior answers.
- Never repeat or closely echo a prior question.
- Return ONLY the question text — no explanation, no numbering, no quotes.`;

  try {
    const q = await callAI(prompt, 120);
    currentQuestion = q.replace(/^["']|["']$/g, '').replace(/^\d+\.\s*/, '');
    questionCount++;
    setCounter(questionCount);
    showQuestion(currentQuestion);
  } catch(e) {
    if (e.message.includes('Invalid API key')) { resetKey(); showSetup(e.message); return; }
    render(`<div class="card"><div class="err">${e.message}</div><button class="btn-primary" onclick="askQuestion()">Retry</button></div>`);
  }
}

function showQuestion(q) {
  const histHtml = history.length
    ? `<div class="history">${history.map(h => `
        <div class="hist-item">
          <span class="hist-q">${h.q}</span>
          <span class="hist-a">${h.a}</span>
        </div>`).join('')}</div>`
    : '';

  render(`
    ${histHtml}
    <div class="card">
      <div class="card-label">Question ${questionCount} of ${MAX_Q}</div>
      <div class="question-text">${q}</div>
    </div>
    <div class="btns">
      <button class="btn-yes" onclick="answer('Yes')">Yes</button>
      <button class="btn-no" onclick="answer('No')">No</button>
      <button class="btn-maybe" onclick="answer('Maybe / Not sure')">Maybe</button>
      ${questionCount >= 5 ? `<button class="btn-ghost" onclick="makeGuess()">Guess now →</button>` : ''}
    </div>
  `);
}

function answer(a) {
  history.push({ q: currentQuestion, a });
  if (questionCount >= MAX_Q) { makeGuess(); return; }
  askQuestion();
}

async function makeGuess() {
  render(`<div class="card"><div class="thinking">Analyzing all the clues...</div></div>`);
  const histText = history.map(h => `Q: ${h.q}\nA: ${h.a}`).join('\n');
  const prompt = `You are playing 20 questions. Based on the clues below, make your single best guess at what the person is thinking of.

${histText}

Respond ONLY with valid JSON (no markdown fences):
{"guess": "your best guess", "confidence": "high/medium/low", "reasoning": "one short sentence"}`;

  try {
    let raw = await callAI(prompt, 250);
    raw = raw.replace(/```json|```/g, '').trim();
    const p = JSON.parse(raw);
    showGuess(p.guess, p.confidence, p.reasoning);
  } catch(e) {
    if (e.message.includes('Invalid API key')) { resetKey(); showSetup(e.message); return; }
    render(`<div class="card"><div class="err">${e.message}</div><button class="btn-primary" onclick="makeGuess()">Retry</button></div>`);
  }
}

function showGuess(guess, conf, reasoning) {
  const confColor = conf === 'high' ? '#0a6647' : conf === 'medium' ? '#7a5510' : '#8f3a1b';
  const safe = guess.replace(/\\/g,'\\\\').replace(/'/g,"\\'").replace(/"/g,'&quot;');
  render(`
    <div class="result-center">
      <div class="result-icon">🔮</div>
      <div class="result-title">My guess is...</div>
      <div class="guess-box">
        <div class="guess-label">I think you're thinking of</div>
        <div class="guess-name">${guess}</div>
        <div class="guess-conf" style="color:${confColor}">Confidence: ${conf} &nbsp;·&nbsp; ${reasoning}</div>
      </div>
      <div style="font-size:15px;color:#666;margin-bottom:1rem;">Was I right?</div>
      <div class="btns" style="justify-content:center;">
        <button class="btn-yes" onclick="endGame(true,'${safe}')">Yes! 🎉</button>
        <button class="btn-no" onclick="endGame(false,'${safe}')">No 😅</button>
      </div>
    </div>
  `);
}

function endGame(correct, guessedAnswer) {
  if (correct) {
    saveLearned({ answer: guessedAnswer, correct: true });
    render(`
      <div class="result-center">
        <div class="result-icon">🎉</div>
        <div class="result-title">Got it!</div>
        <div class="result-sub">I guessed <strong>${guessedAnswer}</strong> in ${questionCount} question${questionCount !== 1 ? 's' : ''}!</div>
        <button class="btn-primary" onclick="showStart()">Play again →</button>
      </div>
    `);
  } else {
    render(`
      <div class="result-center">
        <div class="result-icon">🤔</div>
        <div class="result-title">I was wrong!</div>
        <div class="result-sub">What were you thinking of?<br>Tell me and I'll learn for next time.</div>
        <input type="text" id="real-answer" placeholder="e.g. The Eiffel Tower" style="max-width:320px;" />
        <div class="btns" style="justify-content:center;">
          <button class="btn-primary" onclick="learnAndEnd()">Teach me →</button>
          <button class="btn-ghost" onclick="showStart()">Skip</button>
        </div>
      </div>
    `);
    setTimeout(() => {
      const inp = document.getElementById('real-answer');
      if (inp) inp.addEventListener('keydown', e => { if (e.key === 'Enter') learnAndEnd(); });
    }, 50);
  }
}

function learnAndEnd() {
  const val = (document.getElementById('real-answer').value || '').trim();
  if (val) saveLearned({ answer: val, correct: false, history: history.map(h => h.q + ' → ' + h.a) });
  render(`
    <div class="result-center">
      <div class="result-icon">📚</div>
      <div class="result-title">Thanks, I'll remember that!</div>
      <div class="result-sub">${val ? `"${val}" is now in my memory.<br>I'll use it to ask smarter questions next time.` : 'Better luck next time!'}</div>
      <button class="btn-primary" onclick="showStart()">Play again →</button>
    </div>
  `);
}

loadState();
if (apiKey) { showUI(true); showStart(); }
else showSetup();
</script>
</body>
</html>
